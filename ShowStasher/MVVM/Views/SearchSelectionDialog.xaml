<Window x:Class="ShowStasher.MVVM.Views.SearchSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:ShowStasher.Helpers"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="Select Match"
        Height="600"
        Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="500"
        MinHeight="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Reusable ScrollBar and ScrollViewer Styles to keep ListBox uniform -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Background="Transparent" BorderThickness="0" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Margin="2" CornerRadius="3" Background="#4B5563"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Background="Transparent" BorderThickness="0" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Track" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded Button Template Matching Main App buttons -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Custom Main App Container Structure -->
    <Border x:Name="RootBorder"
            Background="White"
            CornerRadius="12"
            BorderBrush="#DDD"
            BorderThickness="1"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0"
                    Background="#FBFCFD"
                    BorderBrush="LightGray"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    MouseDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                        <Image Source="/Assets/Images/top-image.png"
                               Width="30"
                               Height="30"
                               Margin="0,0,8,0" />
                        <TextBlock Text="Select Match"
                                   FontSize="18"
                                   FontFamily="Inter"
                                   FontWeight="ExtraBold"
                                   VerticalAlignment="Center"
                                   Foreground="#1E293B" />
                    </StackPanel>

                    <!-- Windows Controls (Minimize & Close) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Width="40" Height="40" Background="Transparent" BorderThickness="0" Click="Minimize_Click">
                            <svgc:SvgViewbox Source="/Assets/SVG/minimize.svg" Width="16" Height="16" />
                        </Button>
                        <Button Width="40" Height="40" Background="Transparent" BorderThickness="0" Click="MaximizeRestore_Click">
                            <svgc:SvgViewbox Source="/Assets/SVG/maximize.svg" Width="16" Height="16" />
                        </Button>
                        <Button Width="40" Height="40" Background="Transparent" BorderThickness="0" Click="Close_Click">
                            <svgc:SvgViewbox Source="/Assets/SVG/close.svg"
                                Width="16"
                                Height="16" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Workspace Elements Layout -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Prompt -->
                <TextBlock Grid.Row="0"
                           Text="{Binding PromptMessage}"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="#1E293B"
                           TextWrapping="Wrap"
                           Margin="0,0,0,15" />

                <!-- Posters Grid -->
                <ListBox Grid.Row="1"
                     ItemsSource="{Binding Candidates}"
                     SelectedItem="{Binding SelectedCandidate}"
                     Background="White"
                     BorderBrush="#E2E8F0"
                     BorderThickness="1"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
                    </ListBox.Resources>

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" Margin="8" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="8"
                    Padding="6"
                    CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="Transparent"
                    Background="White">
                                <StackPanel Width="120">
                                    <Image Source="{Binding FullPosterUrl}"
                           Width="120"
                           Height="180"
                           Stretch="Uniform"
                           Margin="0,0,0,6"
                           SnapsToDevicePixels="True" />
                                    <TextBlock Text="{Binding DisplayTitle}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       Foreground="#1E293B"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       Height="40"
                                       Background="Transparent"
                                       LineStackingStrategy="BlockLineHeight"
                                       LineHeight="16" 
                                       helpers:TextBlockExtensions.AutoToolTipIfTrimmed="True" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="BorderBrush" Value="#3B82F6" />
                                    <Setter Property="BorderThickness" Value="2" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.3" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Bottom Action Buttons Layout -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="OK"
                            Width="90"
                            Height="35"
                            Margin="0,0,10,0"
                            Background="#3B82F6"
                            Foreground="White"
                            FontFamily="Inter"
                            FontWeight="Bold"
                            Style="{StaticResource RoundedButton}"
                            Command="{Binding ConfirmCommand}"
                            IsDefault="True" />

                    <Button Content="Cancel"
                            Width="90"
                            Height="35"
                            Background="#F1F5F9"
                            Foreground="#475569"
                            FontFamily="Inter"
                            FontWeight="Bold"
                            Style="{StaticResource RoundedButton}"
                            Command="{Binding CancelCommand}"
                            IsCancel="True" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
